# LLM API configuration (supports any OpenAI-compatible API)
# Option A — Gemini 2.0 Flash (recommended: fast, cheap, English prompts work best)
#   Get API key: https://aistudio.google.com/app/apikey
LLM_API_KEY=your_gemini_api_key_here
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL_NAME=gemini-2.0-flash

# Option B — Ollama local (for offline/dev testing)
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL_NAME=qwen2.5:7b

# Option C — OpenRouter (qwen2.5-72b or similar)
# LLM_API_KEY=your_openrouter_api_key_here
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL_NAME=qwen/qwen-2.5-72b-instruct

# ===== Zep Knowledge Graph =====
# Free tier sufficient for basic usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# Concurrency: parallel agent LLM calls per round
# 1  = sequential (default — safe for free-tier rate limits)
# 5  = recommended for Gemini/OpenRouter paid tier
# 10 = max useful (18 agents/round, but watch RPM limits)
LLM_MAX_WORKERS=1

# Rate limit: max requests per minute (set to match your API tier)
# 14 = safe margin under Gemini free tier (15 RPM)
# 0  = disabled (paid tier / local Ollama — unlimited)
LLM_RPM_LIMIT=14

# ===== Boost LLM config (optional) =====
# Only include these if using a separate faster/more capable model for heavy steps
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== Memgraph (optional — dep graph persistence) =====
# Set MEMGRAPH_ENABLED=true only when running Memgraph via docker-compose
# Default false = in-memory only (no Docker service needed)
# MEMGRAPH_ENABLED=false
# MEMGRAPH_HOST=localhost
# MEMGRAPH_PORT=7687